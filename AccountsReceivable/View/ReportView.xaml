<UserControl x:Class="AccountsReceivable.View.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:AccountsReceivable.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:ReportViewModel}" mc:Ignorable="d" 
              d:DesignHeight="660" d:DesignWidth="1280" Background="#E5D9EA" >
    <UserControl.Resources>
        <Style x:Key="HeaderTextBlock" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="20 0 10 0"/>
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlock}">
            <Setter Property="Margin" Value="50 8 0 9"/>
            <Setter Property="FontSize" Value="17"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="2 10 0 2">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid Margin="0 10 0 20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal" Margin="0 0 0 10" HorizontalAlignment ="Right">
                    <TextBlock Text="c" Style="{StaticResource HeaderTextBlock}"/>
                    <DatePicker SelectedDate="{Binding FromDate}"  Style="{StaticResource CustomDatepiker}" CalendarStyle="{DynamicResource DatePickerCalendarStyle1}" MinWidth="120" VerticalAlignment="Center"  FontSize="15"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment ="Right">
                    <TextBlock Style="{StaticResource HeaderTextBlock}" Text="по"/>
                    <DatePicker SelectedDate="{Binding ToDate}" Style="{StaticResource CustomDatepiker}" CalendarStyle="{DynamicResource DatePickerCalendarStyle1}" MinWidth="120" VerticalAlignment="Center" FontSize="15" />
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10 0 0 0">
                <StackPanel Orientation="Horizontal" Margin="0 0 0 10" HorizontalAlignment ="Right">
                    <TextBlock Style="{StaticResource HeaderTextBlock}" Text="Категория потребителей"/>
                    <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name" 
                              Style="{DynamicResource MainComboBox}" StaysOpenOnEdit="True"  MinWidth="200" VerticalContentAlignment="Center" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment ="Right">
                    <TextBlock Style="{StaticResource HeaderTextBlock}" Text="Услуга"/>
                    <ComboBox ItemsSource="{Binding Nomenclatures}" SelectedItem="{Binding SelectedNomenclature}" DisplayMemberPath="Name" 
                              Style="{DynamicResource MainComboBox}" StaysOpenOnEdit="True"  MinWidth="200" VerticalContentAlignment="Center" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="2"  Margin="30 0">
                <Button Command="{Binding CalculateCommand}" Style="{StaticResource SecondaryButtonStyle}" Content="🧮 Посчитать"/>
                <Button  Command="{Binding ResetFormCommand}" Margin="30 15 0 0" Content="🔄 Очистить фильтры" Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>
        <Border BorderThickness="0 0 0 3" BorderBrush="#50026E" VerticalAlignment="Bottom" Height="2"/>
        <Border Grid.Row="1" BorderBrush="#50026E" BorderThickness="2" CornerRadius="8" Margin="0 20 0 0" HorizontalAlignment="Center" Padding="20 10"
                VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition MinWidth="250"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Результаты отчёта" Grid.Row="0" Grid.ColumnSpan="2" FontSize="19" FontWeight="Bold" Margin="0 10 0 10" HorizontalAlignment="Center"/>
                <Border Grid.Row="1" Grid.ColumnSpan="2" Height="2" Background="#50026E" Margin="0 0 0 40"/>
                <TextBlock Text="Услуга" Grid.Row="1"/>
                <TextBlock Text="{Binding ServiceName}" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left"/>
                <TextBlock Text="Объем" Grid.Row="2"/>
                <TextBlock Text="{Binding Volume, StringFormat=N1}" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left"/>
                <TextBlock Text="Ед. измерения" Grid.Row="3"/>
                <TextBlock Text="{Binding Unit}" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="4" Text="Сумма начислений"/>
                <TextBlock Text="{Binding TotalSum, StringFormat=c}" Grid.Row="4" Grid.Column="1"  HorizontalAlignment="Left"/>
                <Border Grid.Row="5" Grid.ColumnSpan="2" Height="2" Background="#50026E" Margin="0 0 0 40"/>
                <TextBlock Grid.Row="5" Text="Категория потребителей" Margin="30 30 0 0"/>
                <TextBlock Text="{Binding CategoryCompany}" Grid.Row="5" Grid.Column="1" Margin="50 30 0 0" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="6" Text="Период" />
                <TextBlock Text="{Binding PeriodDisplay}" Grid.Row="6" Grid.Column="1" HorizontalAlignment="Left"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
