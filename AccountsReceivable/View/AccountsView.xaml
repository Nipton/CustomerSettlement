<UserControl x:Class="AccountsReceivable.View.AccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:viewmodels="clr-namespace:AccountsReceivable.ViewModels"  d:DataContext="{d:DesignInstance Type=viewmodels:AccountsJournalViewModel}"
             mc:Ignorable="d" xmlns:i="http://schemas.microsoft.com/xaml/behaviors" xmlns:helpers="clr-namespace:AccountsReceivable.Helpers"
             d:DesignHeight="660" d:DesignWidth="1280" Background="#E5D9EA" MouseDown="OnBackgroundClick">
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="20 0 10 0"/>
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="MoneyWrapText" BasedOn="{StaticResource WrapText}">
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </UserControl.Resources>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="150"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.3*" MinHeight="150"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="1" Grid.ColumnSpan="4" BorderThickness="0 0 0 3" BorderBrush="#50026E" VerticalAlignment="Bottom" Height="1"/>
        <Grid Grid.ColumnSpan="3" Margin="10 15 40 10" MinWidth="810">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <Button Content="➕ Добавить счёт" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenAccountEditorCommand}"/>
                <Button Content="💳 Оплатить" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding AddPaymentCommand}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.ColumnSpan="3">
                <TextBlock Text="с"/>
                <DatePicker SelectedDate="{Binding FromDate, UpdateSourceTrigger=LostFocus}" Style="{StaticResource CustomDatepiker}" KeyDown="DatePicker_KeyDown"
                            CalendarStyle="{DynamicResource DatePickerCalendarStyle1}" Width="120" VerticalAlignment="Center" FontSize="15"/>
                <TextBlock Text="по"/>
                <DatePicker SelectedDate="{Binding ToDate, UpdateSourceTrigger=LostFocus}" Style="{StaticResource CustomDatepiker}" KeyDown="DatePicker_KeyDown"
                            CalendarStyle="{DynamicResource DatePickerCalendarStyle1}" Width="120" VerticalAlignment="Center" FontSize="15" />
                <TextBox Style="{StaticResource SearchTextBox}" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="180" Margin="20 0 0 0" Height="26"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="10 0 40 10">
            <StackPanel Orientation="Horizontal">
                <Button Content="✏️ Редактировать" Command="{Binding EditAccountHeaderCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Content="🗑 Удалить" Command="{Binding DeleteAccHeaderCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🖨️ Печать счета" Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Content="📝 Печать акта" Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>
        <TextBlock Grid.Row="2" Text="Счета" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="20" Margin="5"/>
        <TextBlock Grid.Row="2" Grid.Column="2" Text="Состав счёта" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="20"  Margin="5"/>

        <DataGrid x:Name="AccHeadersDataGrid" ItemsSource="{Binding AccountHeadersView}" SelectedItem="{Binding SelectedAccHeader}" 
                  Grid.Row="3" Grid.RowSpan="3" Margin="5" MinWidth="200" Style="{StaticResource MainDataGrid}" SelectionMode="Single">
            <DataGrid.ContextMenu>
                <ContextMenu Name="DataGridContextMenu">
                    <MenuItem Header="Оплатить" Command="{Binding AddPaymentCommand}"/>
                    <Separator/>
                    <MenuItem FontWeight="Bold" Header="Печать счета"/>
                    <MenuItem FontWeight="Bold" Header="Печать акта"/>
                    <Separator/>
                    <MenuItem Header="Редактировать запись" Command="{Binding EditAccountHeaderCommand}"/>
                    <MenuItem Header="Копировать" Command="Copy"/>
                    <Separator/>
                    <MenuItem Header="Удалить" Command="{Binding DeleteAccHeaderCommand}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Id}" ElementStyle="{StaticResource WrapText}"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=d}" ElementStyle="{StaticResource WrapText}"/>
                <DataGridTextColumn Header="Контрагент" Binding="{Binding Company.Name}" ElementStyle="{StaticResource WrapText}" Width="*"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Sum, StringFormat=N2}" ElementStyle="{StaticResource MoneyWrapText}" MinWidth="80" Width="Auto"/>
                <DataGridTextColumn Header="Оплачено" Binding="{Binding PaymentSum, StringFormat=N2}" ElementStyle="{StaticResource MoneyWrapText}" MinWidth="80" Width="Auto"/>
                <DataGridTextColumn Header="Договор" Binding="{Binding Contract.Number}" ElementStyle="{StaticResource WrapText}"/>
                <DataGridTextColumn Header="Дата договора" Binding="{Binding Contract.Date, StringFormat=d}" ElementStyle="{StaticResource WrapText}"/>
                <DataGridTemplateColumn Header="Статус">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#50026E"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#7E20A3"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="ToolTip" Value="Не оплачено"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="True">
                                                <Setter Property="Text" Value="✔"/>
                                                <Setter Property="Foreground" Value="LimeGreen"/>
                                                <Setter Property="ToolTip" Value="Оплачено"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="False">
                                                <Setter Property="Text" Value="✘"/>
                                                <Setter Property="Foreground" Value="DarkRed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <GridSplitter Grid.Column="1" Grid.Row="3" Grid.RowSpan="3"  Width="5" VerticalAlignment="Stretch" HorizontalAlignment="Center" Background="#E5D9EA"/>


        <DataGrid ItemsSource="{Binding AccountLines}" Grid.Row="3" Grid.Column="2" Margin="5" Style="{StaticResource MainDataGrid}">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Редактировать счета" Command="{Binding EditAccountHeaderCommand}"/>
                    <MenuItem Header="Копировать" Command="Copy"/>
                    <MenuItem Header="Удалить" Command="{Binding DeleteAccLinesCommand}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Nomenclature.Name}" ElementStyle="{StaticResource WrapText}" Header="Номенклатура" MinWidth="118" Width="*"/>
                <DataGridTextColumn Binding="{Binding Quantity}" ElementStyle="{StaticResource WrapText}" Header="Количество" MinWidth="60"/>
                <DataGridTextColumn Binding="{Binding Nomenclature.Unit}" ElementStyle="{StaticResource WrapText}" Header="Ед. измер" MinWidth="60"/>
                <DataGridTextColumn Binding="{Binding Price, StringFormat=N2}" ElementStyle="{StaticResource WrapText}" Header="Цена" MinWidth="60" Width="*"/>
                <DataGridTextColumn Binding="{Binding VatRate}" ElementStyle="{StaticResource WrapText}" Header="НДС" MinWidth="60"/>
                <DataGridTextColumn Binding="{Binding AmountWithVat, StringFormat=N2}" ElementStyle="{StaticResource MoneyWrapText}" Header="Сумма" MinWidth="80" Width="*"/>
            </DataGrid.Columns>
            <i:Interaction.Behaviors>
                <helpers:DataGridSelectedItemsBehavior SelectedItems="{Binding SelectedAccountLines, Mode=OneWayToSource}"/>
            </i:Interaction.Behaviors>
        </DataGrid>
        <GridSplitter Grid.Column="2" Grid.Row="4" Height="5" VerticalAlignment="Center" HorizontalAlignment="Stretch" Background="#E5D9EA"/>
        <Grid Grid.Row="5" Grid.Column="2" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Оплата" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="20" Margin="5"/>
            <DataGrid Grid.Row="1" ItemsSource="{Binding Payments}" x:Name="paymentDataGrid" VerticalAlignment="Stretch" Margin="5" MinWidth="500" Style="{StaticResource MainDataGrid}">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Добавить оплату" Command="{Binding AddPaymentCommand}"/>
                        <Separator/>
                        <MenuItem Header="Редактировать" Command="{Binding EditPaymentCommand}"/>
                        <MenuItem Header="Копировать" Command="Copy"/>
                        <Separator/>
                        <MenuItem Header="Удалить" Command="{Binding DeletePaymentsCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Number}" Header="Номер п/п"/>
                    <DataGridTextColumn Binding="{Binding Date, StringFormat=d}" Header="Дата"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding Sum, StringFormat=N2}" ElementStyle="{StaticResource WrapText}" />
                </DataGrid.Columns>
                <i:Interaction.Behaviors>
                    <helpers:DataGridSelectedItemsBehavior SelectedItems="{Binding SelectedPayments, Mode=OneWayToSource}"/>
                </i:Interaction.Behaviors>
            </DataGrid>
            <StackPanel Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Left" Orientation="Horizontal" Margin=" 5 5 0 15">
                <Button Content="✏️ Редактировать оплату" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding EditPaymentCommand}"/>
                <Button Content="🗑 Удалить" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DeletePaymentsCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
