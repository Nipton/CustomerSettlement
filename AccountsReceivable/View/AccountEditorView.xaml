<Window x:Class="AccountsReceivable.View.AccountEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AccountsReceivable.View" xmlns:viewmodels="clr-namespace:AccountsReceivable.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:AccountEditorViewModel}"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" SizeToContent="Height" MinWidth="450" Width="750" WindowStartupLocation="CenterScreen" Language="ru-RU" >
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource MainComboBox}">
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
        <Style x:Key="LocalTextBox" TargetType="TextBox" BasedOn="{StaticResource BaseTextBox}">
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="MaxLength" Value="20"/>
            <EventSetter Event="GotFocus" Handler="TextBox_GotFocus"/>
        </Style>
        <Style TargetType="DatePicker" BasedOn="{StaticResource CustomDatepiker}">
            <Setter Property="CalendarStyle" Value="{StaticResource DatePickerCalendarStyle1}"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="Purple"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="30 0 30 20"/>
        </Style>
    </Window.Resources>
    <Grid Margin="0 20 0 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="300"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <GroupBox Header="Основные данные счёта">
            <Grid Margin="5 20 5 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*" MaxWidth="260"/>
                    <ColumnDefinition Width="0.5*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Контрагент"/>
                <TextBlock Text="Договор" Grid.Row="1"/>
                <TextBlock Text="Дата счёта" Grid.Row="2"/>
                <ComboBox  ItemsSource="{Binding Companies}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedCompany}" Grid.Column="2"/>
                <ComboBox x:Name="CompanyComboBox" ItemsSource="{Binding Contracts}" DisplayMemberPath="Number" SelectedItem="{Binding SelectedContract}" Grid.Row="1" Grid.Column="2"/>
                <DatePicker SelectedDate="{Binding DateAccount}" Grid.Row="2" Grid.Column="2"/>
                <Button Grid.Column="3" Grid.Row="1" Margin="50 0 0 15" Command="{Binding ClearSelectionCommand}" Content="🔄 Сбросить фильтры" Style="{StaticResource SecondaryButtonStyle}" FontSize="16"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Header="{Binding HeaderAccountsLine}">
            <Grid Margin="0 20 0 0">
                <Grid 
                    Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid Style="{StaticResource MainDataGrid}" MinHeight="143" SelectionMode="Single" x:Name="AccountLineDataGrid"
                              SelectedItem="{Binding SelectedAccountLine}" ItemsSource="{Binding AccountLines}" FontWeight="Normal">

                        <DataGrid.Columns>
                            <DataGridTextColumn ElementStyle="{StaticResource WrapText}" Binding="{Binding Nomenclature.Name}" Header="Номенклатура" Width="1.8*" MinWidth="190"/>
                            <DataGridTextColumn Binding="{Binding Price, StringFormat=N2}" Header="Цена" MinWidth="110"  Width="*"/>
                            <DataGridTextColumn Binding="{Binding Quantity, StringFormat=N1}" Header="Количество" MinWidth="100"/>
                            <DataGridTextColumn Binding="{Binding Nomenclature.Unit}" Header="Ед. изм." MinWidth="70"/>
                            <DataGridTextColumn Binding="{Binding VatRate}" Header="НДС" MinWidth="60"/>
                            <DataGridTextColumn Binding="{Binding AmountWithVat, StringFormat=N2}" Header="Сумма"  Width="*" MinWidth="110"/>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu Name="DataGridContextMenu">
                                <MenuItem Header="Копировать" Command="Copy"></MenuItem>
                                <MenuItem Header="Редактировать" Command="{Binding EditAccountLineCommand}" ></MenuItem>
                                <MenuItem Header="Удалить" Command="{Binding RemoveAccountLineCommand}" ></MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                    <DockPanel Grid.Row="1" Margin="10 10"  LastChildFill="False">
                        <Button Command="{Binding AddNewLineCommand}" Content="+ Добавить позицию" DockPanel.Dock="Left" Style="{StaticResource SecondaryButtonStyle}" FontSize="16"/>
                        <Button Command="{Binding RemoveAccountLineCommand}" Content="Удалить" DockPanel.Dock="Right" Style="{StaticResource SecondaryButtonStyle}" FontSize="16"/>
                        <Button Command="{Binding EditAccountLineCommand}" Content="Изменить" DockPanel.Dock="Right"  Style="{StaticResource SecondaryButtonStyle}" FontSize="16"/>
                        
                    </DockPanel>
                </Grid>
                <Grid Margin="10 15 10 0" Grid.IsSharedSizeScope="True"
                      Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*" MaxWidth="300"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" SharedSizeGroup="Row0"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="Row1"/>
                            <RowDefinition Height="Auto"  SharedSizeGroup="Row2"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="Row3"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Номенклатура"/>
                        <ComboBox ItemsSource="{Binding Nomenclatures}" SelectedItem="{Binding SelectedNomenclature}" Grid.Row="0" Grid.Column="2" 
                                  Height="{Binding ElementName=CompanyComboBox, Path=ActualHeight}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontSize="16" Text="{Binding Name}"/>
                                        <TextBlock FontSize="12" Text="{Binding Unit}" FontWeight="Light"  Margin="0 0 0 2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Количество"/>
                        <TextBox Style="{StaticResource LocalTextBox}" x:Name="QuantityTextBox" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Stretch"
                                 Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource ValidatingDecimalConverter}, ValidatesOnDataErrors=True}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Цена"/>
                        <TextBox Style="{StaticResource LocalTextBox}" Grid.Row="2" Grid.Column="2"
                                 Text="{Binding Price, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource ValidatingDecimalConverter}, ValidatesOnDataErrors=True, StringFormat=c}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Период"/>
                        <DatePicker Grid.Row="3" Grid.Column="2" SelectedDate="{Binding Period}"/>
                    </Grid>
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" SharedSizeGroup="Row0"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="Row1"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="Row2"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="Row3"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="НДС"/>
                        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="40 0 0 0">
                            <TextBox  Style="{StaticResource LocalTextBox}" Text="{Binding VatRate, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource ValidatingDecimalConverter}, ValidatesOnDataErrors=True}" Width="50"
                                     Height="{Binding ElementName=QuantityTextBox, Path=ActualHeight}" MaxLength="5"/>
                            <TextBlock Text="%" Margin="5 0 0 15"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Сумма без НДС"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding AmountWithoutVat, StringFormat=c}" HorizontalAlignment="Left"  Margin="40 0 0 15"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Сумма НДС"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding VatSum, StringFormat=c}" HorizontalAlignment="Left" Margin="40 0 0 15"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Итого"/>
                        <TextBlock  Grid.Row="3" Grid.Column="2" Text="{Binding AmountWithVat, StringFormat=c}" HorizontalAlignment="Left"  Margin="40 0 0 15"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Grid.ColumnSpan="3" Grid.Row="1" Margin="0 20 40 10">
                        <Button Command="{Binding FinishEditLineCommand}" Content="Отмена" Style="{StaticResource SecondaryButtonStyle}" FontSize="16"/>
                        <Button Command="{Binding SaveNewLineCommand}" Content="Сохранить позицию" Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="16"/>
                    </StackPanel>
                   
                </Grid>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="2" Header="Итоги">
            <Grid Margin="50 20 0 0">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Сумма счёта:" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="1" Text="В т.ч. НДС:" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="2" Text="{Binding TotalAccountSum, StringFormat=c}" HorizontalAlignment="Left" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding TotalVatSum, StringFormat=c}" HorizontalAlignment="Left" />
            </Grid>
        </GroupBox>
        <Border Grid.Row="3" Background="#E5D9EA"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20 10">
            <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding CancelCommand}" Content="Отмена" MinWidth="110" Margin="20 0"/>
            <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveAllCommand}" Content="Сохранить"  MinWidth="110"/>
        </StackPanel>
    </Grid>
</Window>
